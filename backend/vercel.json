{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "lib/**",
          "routes/**",
          "controllers/**",
          "middleware/**",
          "models/**",
          "services/**",
          "utils/**",
          "initDefaults.js"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
